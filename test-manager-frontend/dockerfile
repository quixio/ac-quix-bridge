# Stage 1: Build
FROM node:20-bookworm-slim AS builder
WORKDIR /app

# Accept build arguments for Next.js (needed at build time for NEXT_PUBLIC_ vars)
ARG API_URL=http://test-manager-backend
ENV API_URL=$API_URL

ARG NEXT_PUBLIC_TELEMETRY_EXPLORER_URL
ENV NEXT_PUBLIC_TELEMETRY_EXPLORER_URL=$NEXT_PUBLIC_TELEMETRY_EXPLORER_URL

ARG NEXT_PUBLIC_LAKEHOUSE_UI_URL
ENV NEXT_PUBLIC_LAKEHOUSE_UI_URL=$NEXT_PUBLIC_LAKEHOUSE_UI_URL

ARG NEXT_PUBLIC_FREEZE_MS
ENV NEXT_PUBLIC_FREEZE_MS=$NEXT_PUBLIC_FREEZE_MS

# Copy package files
COPY package*.json ./

# Install all dependencies (needed for build)
RUN npm install --legacy-peer-deps

# Copy source code
COPY . .

# Build Next.js for production
RUN npm run build

# Stage 2: Production runtime
FROM node:20-bookworm-slim
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install only production dependencies
RUN npm install --legacy-peer-deps --omit=dev

# Copy built Next.js app from builder stage
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.js ./

# Set production environment
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Expose Next.js port
EXPOSE 3000

# Start Next.js in production mode

CMD ["npm", "start"]
