# Development Dockerfile for Test Manager Next.js Frontend
# Using Debian-based image for Playwright compatibility
FROM node:20-bookworm-slim

# Install essential tools and Playwright dependencies
RUN apt-get update && apt-get install -y \
    git \
    bash \
    curl \
    ca-certificates \
    # Playwright system dependencies
    libglib2.0-0 \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxcb1 \
    libxkbcommon0 \
    libatspi2.0-0 \
    libx11-6 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install global packages
RUN npm install -g \
    npm@latest \
    typescript \
    @types/node

# Create a non-root user
RUN groupadd -g 1001 nodejs && \
    useradd -u 1001 -g nodejs -s /bin/bash -m nextjs

# Copy package files and install dependencies
# This ensures dependencies are installed during build
COPY package*.json ./
RUN npm install

# Set environment for development
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Expose ports
# 3000 - Next.js dev server
# 3001 - Next.js Fast Refresh
EXPOSE 3000 3001

# Default command (will be overridden by docker-compose)
CMD ["npm", "run", "dev"]
