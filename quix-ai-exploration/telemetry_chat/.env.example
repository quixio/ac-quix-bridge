# Quix Portal + AI
QUIX_PORTAL_API=https://portal-api.dev.quix.io
QUIX_TOKEN=

# QuixLake Querier agent — overrides the default if you fork the agent.
# Default: d578e2f5-c2b7-461a-90d2-70dfac450fb0
# QUIX_AI_AGENT_ID=

# QuixLake — same values telemetry-comparison uses
QUIXLAKE_URL=
QUIX_LAKE_TOKEN=
TABLE_NAME=ac_telemetry

# DEBUG surfaces every Quix AI SSE event (text_delta, status, usage, etc.)
# to stderr in real time. Useful while iterating on the system prompt.
# INFO is the default and stays quiet per request.
LOG_LEVEL=INFO
