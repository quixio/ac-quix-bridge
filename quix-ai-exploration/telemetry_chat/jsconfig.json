{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "lib": ["es2022", "dom", "dom.iterable"]
  },
  "include": ["static/**/*.js", "static/**/*.d.ts"],
  "exclude": ["node_modules", "static/**/*.test.js"]
}
