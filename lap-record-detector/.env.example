# Quix SDK Token - find this in the Quix Portal under Settings > Tokens (SDK Tokens section)
Quix__Sdk__Token=

# Topic names (from your Quix environment)
input=ac-telemetry-raw
config_topic=ac-telemetry-config
output=lap-records

# Consumer group
CONSUMER_GROUP=lap-record-detector

# Where to start consuming if no offset exists (earliest/latest)
AUTO_OFFSET_RESET=earliest

# Logging level
LOGLEVEL=INFO
