# Quix Cloud connection — pick ONE of the two modes below.
# QuixStreams' Application() auto-resolves whichever set of vars is present.

# Mode A: SDK token (portal-resolved broker — default for Quix Cloud)
Quix__Sdk__Token=your_sdk_token_here
Quix__Portal__Api=https://portal-api.platform.quix.io
Quix__Workspace__Id=your_workspace_id

# Mode B: Direct broker (alt — bypasses Portal API + its SSL trust requirement)
# Comma-separated bootstrap.servers list. main.py uses security_protocol="sasl_ssl",
# sasl_mechanism="SCRAM-SHA-512", enable_ssl_certificate_verification=False,
# ssl_endpoint_identification_algorithm="none".
# Quix__Broker__Address=kafka-0-...:30095,kafka-1-...:30095,kafka-2-...:30095
# Quix__Broker__Username=workspace_name
# Quix__Broker__Password=your_broker_password

# Topics
output=ac-telemetry-raw
session_output=ac-telemetry-session

# Source sampling
SAMPLE_RATE_HZ=50
