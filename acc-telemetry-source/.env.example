# Quix Cloud connection — pick ONE of the two modes below.
# QuixStreams' Application() auto-resolves whichever set of vars is present.

# Mode A: SDK token (portal-resolved broker — default for Quix Cloud)
Quix__Sdk__Token=your_sdk_token_here
Quix__Portal__Api=https://portal-api.platform.quix.io
Quix__Workspace__Id=your_workspace_id

# Mode B: Direct broker (alt — embeds auth inline, skip Portal API)
# Quix__Broker__Address=your_broker_url_with_auth

# Topics
output=acc-telemetry-raw
session_output=acc-telemetry-session

# Source sampling
SAMPLE_RATE_HZ=50
