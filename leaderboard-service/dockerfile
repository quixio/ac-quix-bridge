# Stage 1: UI build (Next.js static export). Node exists only here —
# the final image is Python-only. Build context = repo root.
FROM node:20-bookworm-slim AS ui-builder
WORKDIR /ui

# Quix Cloud injects deployment variables as build args.
ARG NEXT_PUBLIC_FREEZE_MS
ENV NEXT_PUBLIC_FREEZE_MS=$NEXT_PUBLIC_FREEZE_MS
# Standalone-mode fallback PAT baked into the bundle (unchanged behavior).
ARG NEXT_PUBLIC_QUIX_AUTH_TOKEN
ENV NEXT_PUBLIC_QUIX_AUTH_TOKEN=$NEXT_PUBLIC_QUIX_AUTH_TOKEN
ENV NEXT_TELEMETRY_DISABLED=1

COPY leaderboard-ui/package*.json ./
RUN npm ci --legacy-peer-deps
COPY leaderboard-ui/ .
RUN npm run build
# emits /ui/out (next.config.js output: 'export')

# Stage 2: Python runtime
FROM python:3.13-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
	PYTHONUNBUFFERED=1 \
	PYTHONIOENCODING=UTF-8 \
	UV_COMPILE_BYTECODE=1

ARG MAINAPPPATH=leaderboard-service

WORKDIR /app

# Install system dependencies for healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Copy project (build context = repo root, MAINAPPPATH = app subdir)
COPY "${MAINAPPPATH}" /app

# Install dependencies with uv
RUN uv sync --frozen --no-cache

# Static UI served by FastAPI at / (see api/app.py, STATIC_DIR)
COPY --from=ui-builder /ui/out /app/static

ENV PYTHONPATH=/app
EXPOSE 8080

# Start the API using uv to run the module
ENTRYPOINT ["/bin/uv", "run", "-m", "main"]
