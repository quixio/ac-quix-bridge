# Copy to a per-environment file and fill in:
#   .env            -> default (QUIX_ENV unset)
#   .env.dev        -> QUIX_ENV=dev
#   .env.byox       -> QUIX_ENV=byox
#
# Select which file the scripts use:
#   QUIX_ENV=byox uv run update_agent.py --agent ac-telemetry-agent
#
# Shell env wins over the file. Scripts also append the ids they generate
# (agent/kb/mcp) below — each environment keeps its own.

# --- credentials (you fill these in, per environment) ---
QUIX_PORTAL_API=https://portal-api.platform.quix.io
QUIX_TOKEN=<personal access token for this environment>
QUIX_WORKSPACE_ID=<workspace id>

# Self-signed clusters only (e.g. BYOX): path to the CA chain so TLS verifies.
# Leave blank for clusters with a public cert.
QUIX_CA_BUNDLE=

# --- generated by the scripts (leave blank; written on first run) ---
AC_TELEMETRY_KB_ID=
QUIX_AI_AC_TELEMETRY_AGENT_ID=
POST_RACE_SUMMARY_KB_ID=
QUIX_AI_POST_RACE_AGENT_ID=
