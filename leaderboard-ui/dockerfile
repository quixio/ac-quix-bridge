# Stage 1: Build
FROM node:20-bookworm-slim AS builder
WORKDIR /app

ARG API_URL=http://leaderboard-service
ENV API_URL=$API_URL

ARG NEXT_PUBLIC_LEADERBOARD_SERVICE_URL
ENV NEXT_PUBLIC_LEADERBOARD_SERVICE_URL=$NEXT_PUBLIC_LEADERBOARD_SERVICE_URL

ARG NEXT_PUBLIC_FREEZE_MS
ENV NEXT_PUBLIC_FREEZE_MS=$NEXT_PUBLIC_FREEZE_MS

# Bake the workspace PAT into the bundle so the standalone UI can
# authenticate against leaderboard-service's `validate_permissions` gate.
# Same value as `Quix__Lakehouse__Query__AuthToken` /
# `Quix__Lakehouse__Catalog__AuthToken` — they all resolve to the
# workspace's PAT in this BYOX setup.
ARG NEXT_PUBLIC_QUIX_AUTH_TOKEN
ENV NEXT_PUBLIC_QUIX_AUTH_TOKEN=$NEXT_PUBLIC_QUIX_AUTH_TOKEN

COPY package*.json ./
RUN npm install --legacy-peer-deps
COPY . .
RUN npm run build

# Stage 2: Runtime
FROM node:20-bookworm-slim
WORKDIR /app
COPY package*.json ./
RUN npm install --legacy-peer-deps --omit=dev
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.js ./
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
EXPOSE 3000
CMD ["npm", "start"]
