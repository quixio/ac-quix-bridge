<Window x:Class="AccOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ACC Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Focusable="False"
        IsHitTestVisible="False"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Palette mirrors the scichart dashboard. -->
        <SolidColorBrush x:Key="Cyan"  Color="#00D4FF" />
        <SolidColorBrush x:Key="Green" Color="#00FF88" />
        <SolidColorBrush x:Key="Amber" Color="#FFAA00" />
        <SolidColorBrush x:Key="Red"   Color="#FF3355" />
        <SolidColorBrush x:Key="Dim"   Color="#8A8AA5" />
        <SolidColorBrush x:Key="Text"  Color="#F0F0F5" />
        <SolidColorBrush x:Key="CardBg"     Color="#B0090910" />
        <SolidColorBrush x:Key="CardBorder" Color="#3F2A2A45" />
        <SolidColorBrush x:Key="RingDim"    Color="#33335A" />
        <SolidColorBrush x:Key="RingOuter"  Color="#4D4D7A" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Dim}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Centre-top cluster. LayoutTransform applies the configurable Scale. -->
        <StackPanel x:Name="Root"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
            <StackPanel.LayoutTransform>
                <ScaleTransform x:Name="ClusterScale" ScaleX="1" ScaleY="1" />
            </StackPanel.LayoutTransform>

            <!-- ===================== G-FORCE ===================== -->
            <Border Style="{StaticResource Card}">
                <StackPanel Width="172">
                    <TextBlock Style="{StaticResource CardTitle}" Text="G-FORCE" Margin="0,0,0,6" />

                    <Viewbox Width="150" Height="150" HorizontalAlignment="Center">
                        <!-- 200x200 coordinate space; centre at (100,100), 30 px per g. -->
                        <Canvas Width="200" Height="200">
                            <Ellipse Width="60"  Height="60"  Canvas.Left="70" Canvas.Top="70"
                                     Stroke="{StaticResource RingDim}" StrokeThickness="1" />
                            <Ellipse Width="120" Height="120" Canvas.Left="40" Canvas.Top="40"
                                     Stroke="{StaticResource RingDim}" StrokeThickness="1" />
                            <Ellipse Width="180" Height="180" Canvas.Left="10" Canvas.Top="10"
                                     Stroke="{StaticResource RingOuter}" StrokeThickness="1.2" />

                            <Line X1="10" Y1="100" X2="190" Y2="100" Stroke="{StaticResource RingDim}" StrokeThickness="1" />
                            <Line X1="100" Y1="10" X2="100" Y2="190" Stroke="{StaticResource RingDim}" StrokeThickness="1" />

                            <TextBlock Canvas.Left="100" Canvas.Top="0" Text="ACCEL"
                                       Foreground="{StaticResource Dim}" FontSize="9" FontWeight="Bold"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform><TranslateTransform X="-15" /></TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Canvas.Left="100" Canvas.Top="188" Text="BRAKE"
                                       Foreground="{StaticResource Dim}" FontSize="9" FontWeight="Bold">
                                <TextBlock.RenderTransform><TranslateTransform X="-15" /></TextBlock.RenderTransform>
                            </TextBlock>

                            <!-- Vector from centre + the live dot. -->
                            <Line x:Name="GVector" X1="100" Y1="100" X2="100" Y2="100"
                                  Stroke="{StaticResource Cyan}" StrokeThickness="2" Opacity="0.5" />
                            <Ellipse x:Name="GDot" Width="15" Height="15" Canvas.Left="92.5" Canvas.Top="92.5"
                                     Fill="{StaticResource Cyan}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.8" Color="#00D4FF" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Viewbox>

                    <!-- LAT / G / LON readouts -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="LAT" Foreground="{StaticResource Dim}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock x:Name="GLat" Text="0.0" Foreground="{StaticResource Text}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="G" Foreground="{StaticResource Dim}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock x:Name="GTot" Text="0.0" Foreground="{StaticResource Text}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="LON" Foreground="{StaticResource Dim}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock x:Name="GLon" Text="0.0" Foreground="{StaticResource Text}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===================== LEADERBOARD ===================== -->
            <Border Style="{StaticResource Card}" Margin="14,0,0,0">
                <StackPanel Width="300">
                    <!-- Header: title + big predicted position badge -->
                    <Grid Margin="0,0,0,8">
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CardTitle}" Text="PREDICTED" />
                            <TextBlock x:Name="PredTime" Text="--:--.---"
                                       Foreground="{StaticResource Amber}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#1C1C30" CornerRadius="10" Padding="14,2" MinWidth="64">
                            <TextBlock x:Name="PosBadge" Text="P--"
                                       Foreground="{StaticResource Cyan}" FontSize="30" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Rows are built in code-behind. -->
                    <StackPanel x:Name="LbRows" />

                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="{StaticResource Amber}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText" Text="waiting for ACC…" Margin="7,0,0,0"
                                   Foreground="{StaticResource Dim}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
