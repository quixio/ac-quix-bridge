# Quix SDK Token — find this in the Quix Portal under Settings > Tokens (SDK Tokens section)
Quix__Sdk__Token=

# Topic names (from your Quix environment)
output=ac-telemetry-raw
session_output=ac-telemetry-session
config_input=ac-telemetry-config

# DCM base URL (in-cluster default)
CONFIG_API_URL=http://dynamic-configuration-manager

# Lakehouse query URL — auto-injected by Quix Cloud when blobStorage.bind=true
Quix__Lakehouse__Query__Url=
Quix__Lakehouse__Query__AuthToken=

# Lake schema
LAKE_TABLE=ac_telemetry_prod
LAKE_COL_BEST_TIME=iBestTime

# HTTP server
HTTP_PORT=80

# Kafka consumer group
CONSUMER_GROUP=best-times-cache-lite
